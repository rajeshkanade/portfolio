# ---- Environment ----
# MongoDB connection string used by the /api/contact route to store messages.
# Local:  mongodb://127.0.0.1:27017/portfolio
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/portfolio?retryWrites=true&w=majority
#
# On Vercel: add this as an Environment Variable named MONGODB_URI.
# If left unset, the site still works — POST /api/contact returns a friendly
# 503 and the form tells the visitor to email directly.
MONGODB_URI=

# OPTIONAL — a GitHub personal access token (classic, no scopes needed for public
# repos) used by the "More on GitHub" projects grid. Without it, the grid still
# works using the unauthenticated API (the server caches results ~hourly, so the
# 60 requests/hour limit is never a problem). Set it only if you want a higher
# rate limit. Public, read-only — never expose secrets here.
GITHUB_TOKEN=
